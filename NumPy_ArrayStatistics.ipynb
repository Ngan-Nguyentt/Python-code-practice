import numpy as np

arr = np.random.randint(10, 51, size=(5, 5))
print(arr)

mean_value = np.mean(arr)
median_value = np.median(arr)
std_value = np.std(arr)

max_value = np.max(arr)
min_value = np.min(arr)

print(f"Mean value: {mean_value}\nMedian value: {median_value}\nStandard deviation: {std_value}\nMaximum value: {max_value}\nMinimum value: {min_value}")